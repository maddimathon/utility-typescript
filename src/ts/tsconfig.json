{
    "extends": [
        "@tsconfig/node20/tsconfig.json",
        "../../tsconfig.json"
    ],
    "include": [
        "../../src/ts/**/*.ts",
        "./src/ts/**/*.ts"
    ],
    "exclude": [
        "./node_modules/**/*",
        "../../src/ts/**/*.docs.ts",
        "./src/ts/**/*.docs.ts",
        "../../src/ts/**/*.example.ts",
        "./src/ts/**/*.example.ts"
    ],
    "compilerOptions": {
        "declaration": true,
        "declarationMap": false,
        "outDir": "../../dist/",
        "rootDir": "./",
        "sourceMap": false
    },
    "$schema": "https://json.schemastore.org/tsconfig"
}